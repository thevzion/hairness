{
  "apiVersion": "hairness.dev/extension/v1alpha1",
  "kind": "Extension",
  "metadata": { "id": "hairness/codebase", "version": "0.3.0-alpha.0", "summary": "Target repository inspection and maps." },
  "spec": {
    "provides": ["hairness.codebase"],
    "requires": ["hairness.sources"],
    "recipes": [
      { "id": "hairness-map", "path": "recipes/map.md", "summary": "Build a focused live map of a Target.", "capability": "hairness.codebase" }
    ],
    "adapters": [],
    "schemas": [],
    "gates": [],
    "onboarding": [
      { "id": "codebase.focus", "question": "Which part of the first Target should the agent learn first?", "when": { "targetPresent": true }, "explanation": "Maps stay focused and rely on live source evidence." }
    ],
    "tests": []
  }
}

{
  "$schema": "../../../../schemas/capability.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/initiative",
  "owner": "hairness/initiative-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Keep forge initiatives explicit and project only reviewed snapshots.",
  "operations": [
    { "id": "inspect", "class": "observe", "summary": "Inspect active and planned initiatives.", "results": [{ "id": "default", "contract": { "schema": "InitiativePortfolio", "disposition": "run-only" } }], "defaultResult": "default", "sources": [], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] },
    { "id": "plan", "class": "derive", "summary": "Turn a strategic outcome into one bounded initiative.", "results": [{ "id": "default", "contract": { "schema": "InitiativeRecord", "disposition": "run-only" } }], "defaultResult": "default", "sources": [], "effects": [], "routes": ["inline", "worker"], "acceptsModifiers": ["hairness.presentation"] },
    { "id": "publish", "class": "effect", "summary": "Project a reviewed roadmap snapshot into a versioned file.", "results": [{ "id": "default", "contract": { "schema": "ChangeReceipt", "disposition": "effect" } }], "defaultResult": "default", "sources": [], "effects": ["filesystem:write"], "routes": ["worker"], "acceptsModifiers": [] }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/worktree-controls/checkout-request.schema.json",
  "title": "CheckoutRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "repository", "planId", "sessionId", "policyDigest"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "repository": { "$ref": "#/$defs/RepositoryRef" },
    "planId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "policyDigest": { "type": "string", "pattern": "^sha256:" },
    "worktreeId": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "branch": { "type": ["string", "null"] },
    "base": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["branch", "detached"] },
    "commit": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "targetSessionId": { "type": "string", "minLength": 1 },
    "expectedHead": { "type": "string", "minLength": 1 },
    "remoteHead": { "type": "string", "minLength": 1 },
    "published": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "proof": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "bootstrap": { "type": "boolean" },
    "controller": { "type": "boolean" }
  },
  "$defs": {
    "RepositoryRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "workspace" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": { "const": "codebase" },
            "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
            "checkout": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
          }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/worktree-controls/worktree-lease.schema.json",
  "title": "WorktreeLease",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "id", "handleId", "planId", "sessionId", "mode", "state", "acquiredAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "id": { "type": "string", "minLength": 1 },
    "handleId": { "type": "string", "minLength": 1 },
    "planId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "mode": { "const": "writer" },
    "state": { "enum": ["active", "stale", "released"] },
    "previousLeaseId": { "type": ["string", "null"] },
    "reason": { "type": ["string", "null"] },
    "acquiredAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}

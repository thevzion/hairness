{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/worktree-controls/worktree-handle.schema.json",
  "title": "WorktreeHandle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "id", "repository", "planId", "kind", "path", "branch", "base", "head", "detached", "state", "policyDigest", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "id": { "type": "string", "minLength": 1 },
    "repository": { "$ref": "#/$defs/RepositoryRef" },
    "planId": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["branch", "candidate"] },
    "path": { "type": "string", "minLength": 1 },
    "branch": { "type": ["string", "null"] },
    "base": { "type": "string", "minLength": 1 },
    "head": { "type": ["string", "null"] },
    "detached": { "type": "boolean" },
    "state": { "enum": ["active", "cleanup-ready", "blocked", "closed"] },
    "policyDigest": { "type": "string", "pattern": "^sha256:" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "RepositoryRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "root", "remote"],
          "properties": {
            "kind": { "const": "workspace" },
            "root": { "type": "string", "minLength": 1 },
            "remote": { "type": ["string", "null"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id", "checkout", "root", "remote"],
          "properties": {
            "kind": { "const": "codebase" },
            "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
            "checkout": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
            "root": { "type": "string", "minLength": 1 },
            "remote": { "type": ["string", "null"] }
          }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["planId", "scope", "changes", "status", "checkpointId"],
  "properties": {
    "planId": { "type": "string" },
    "scope": { "type": "string" },
    "changes": { "type": "array", "items": { "type": "object" } },
    "status": { "enum": ["ready", "review-required"] },
    "checkpointId": { "type": "string" }
  },
  "additionalProperties": true
}

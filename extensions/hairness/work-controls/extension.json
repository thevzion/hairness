{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/work-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Persistent missions, segments, frames, recaps and plans.",
  "category": "collaboration",
  "tags": ["work", "planning"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/work.json"],
  "dependencies": ["hairness/cockpit", "hairness/presentation-controls"],
  "services": ["state", "set-boundary", "controls"],
  "contributes": ["session-opening", "invocation-controls"],
  "relationTypes": ["continues", "depends-on", "informs", "supersedes", "blocks", "related-to"],
  "commands": [{ "namespace": "work", "actions": ["status", "history", "trace", "resume", "mission", "segment", "frame", "control", "method", "show-method", "show-work", "show-next", "ask-next", "open-frame", "discuss", "new-frame", "make-recap", "save-recap", "recap", "make-plan", "save-plan", "plan", "plan-system-wire", "plan-system-shape", "act", "execute", "do-frame", "do-plan"] }],
  "artifactSchemas": [
    { "type": "segment-digest", "schema": "./schemas/segment-digest.schema.json" },
    { "type": "work-plan", "schema": "./schemas/work-plan.schema.json" }
  ],
  "providerCommands": [
    { "id": "hairness.work", "name": "hairness-work", "summary": "Guide the Work Controls namespace and route active-work intents.", "kind": "capability", "classification": "primary", "surface": "namespace", "command": "hairness work status", "arguments": [{ "name": "action", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md" },
    { "id": "hairness.x.show-method", "name": "hairness-x-show-method", "summary": "Show the active method and how work segments compose.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work show-method", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "method", "persistence": "none" } } },
    { "id": "hairness.x.show-work", "name": "hairness-x-show-work", "summary": "Show the compact active-work dashboard with links, limits and next route.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work show-work", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "work", "persistence": "none" } } },
    { "id": "hairness.x.open-frame", "name": "hairness-x-open-frame", "summary": "Open one bounded work frame after a lightweight checkpoint.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work open-frame", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ChangeReceipt", "disposition": "effect" }, "resultId": "default", "operation": { "capability": "hairness/work", "id": "open-frame" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "state-checkpoint" } } },
    { "id": "hairness.x.discuss", "name": "hairness-x-discuss", "summary": "Discuss one bounded frame without effects or persistence.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work discuss", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "default", "operation": { "capability": "hairness/work", "id": "discuss" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.make-recap", "name": "hairness-x-make-recap", "summary": "Produce a chat recap of active work without saving it.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work make-recap", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "response", "operation": { "capability": "hairness/work", "id": "recap" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.save-recap", "name": "hairness-x-save-recap", "summary": "Persist the active work recap as a typed segment digest.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work save-recap", "arguments": [], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/work-controls", "artifactType": "segment-digest" }, "resultId": "artifact", "operation": { "capability": "hairness/work", "id": "recap" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "artifact" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.make-plan", "name": "hairness-x-make-plan", "summary": "Draft an enriched work plan in chat without saving it.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work make-plan", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.save-plan", "name": "hairness-x-save-plan", "summary": "Persist the accepted enriched work plan artifact.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work save-plan", "arguments": [], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/work-controls", "artifactType": "work-plan" }, "resultId": "artifact", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "persistence": "artifact" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.show-next", "name": "hairness-x-show-next", "summary": "Show the next useful routes for the active work.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work show-next", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "next", "persistence": "none" } } },
    { "id": "hairness.x.ask-next", "name": "hairness-x-ask-next", "summary": "Ask the one next question that unblocks the active work.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work ask-next", "arguments": [], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "question", "persistence": "none" } } },
    { "id": "hairness.x.plan-system-wire", "name": "hairness-x-plan-system-wire", "summary": "Draft a system wiring plan with explicit owner and compatibility controls.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work plan-system-wire", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "planKind": "system-wire", "persistence": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.plan-system-shape", "name": "hairness-x-plan-system-shape", "summary": "Draft a target-shape plan using the reshape-system controls.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work plan-system-shape", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "planKind": "system-shape", "persistence": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.x.do-frame", "name": "hairness-x-do-frame", "summary": "Act on one accepted frame through an explicit checkpoint.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work do-frame", "arguments": [{ "name": "focus", "required": true }], "result": { "schema": "ChangeReceipt", "disposition": "effect" }, "resultId": "default", "operation": { "capability": "hairness/work", "id": "act" }, "instructions": "./commands/work.md", "defaults": { "mode": "auto" }, "fixed": { "controls": { "persistence": "effect-checkpoint" } }, "overrides": ["mode", "budget"] },
    { "id": "hairness.x.do-plan", "name": "hairness-x-do-plan", "summary": "Execute an accepted WorkPlan through bounded routes.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness work do-plan", "arguments": [{ "name": "plan", "required": true }], "result": { "schema": "ContextPacket", "disposition": "effect" }, "resultId": "default", "operation": { "capability": "hairness/work", "id": "execute" }, "instructions": "./commands/work.md", "defaults": { "mode": "auto" }, "fixed": { "controls": { "persistence": "effect-checkpoint" } }, "overrides": ["mode", "budget"] }
  ]
}

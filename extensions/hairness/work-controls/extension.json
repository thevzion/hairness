{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/work-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Persistent missions, segments, frames, recaps and plans.",
  "category": "collaboration",
  "tags": ["work", "planning"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/work.json"],
  "dependencies": ["hairness/cockpit", "hairness/presentation-controls"],
  "services": ["state", "set-boundary", "controls"],
  "contributes": ["attention", "session-opening", "invocation-controls"],
  "relationTypes": ["continues", "depends-on", "informs", "supersedes", "blocks", "related-to"],
  "commands": [{ "namespace": "work", "actions": ["status", "history", "trace", "resume", "mission", "segment", "frame", "control", "method", "show-method", "show-work", "show-trace", "show-next", "ask-next", "open-frame", "discuss", "new-frame", "make-recap", "save-recap", "recap", "make-plan", "save-plan", "plan", "plan-system-wire", "plan-system-shape", "act", "execute", "do-frame", "do-plan"] }],
  "artifactSchemas": [
    { "type": "segment-digest", "schema": "./schemas/segment-digest.schema.json" },
    { "type": "work-plan", "schema": "./schemas/work-plan.schema.json" }
  ],
  "commandSurfaces": [
    { "id": "hairness.work", "summary": "Guide the Work Controls namespace and route active-work intents.", "classification": "primary", "surface": "namespace", "machineRoute": "hairness work show-work", "arguments": [{ "name": "action", "required": false }], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md" },
    { "id": "hairness.work.show-method", "summary": "Show the active method and how work segments compose.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "method" }, "machineRoute": "hairness work show-method", "arguments": [], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "method", "promotion": "none" } } },
    { "id": "hairness.work.show-work", "summary": "Show the compact active-work dashboard with links, limits and next route.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "work" }, "machineRoute": "hairness work show-work", "arguments": [], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "work", "promotion": "none" } } },
    { "id": "hairness.work.show-trace", "summary": "Show the active Invocation, child Runs, results and fan-in trace.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "trace" }, "machineRoute": "hairness work show-trace", "arguments": [], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "trace", "promotion": "none" } } },
    { "id": "hairness.work.open-frame", "summary": "Open one bounded work frame after a lightweight checkpoint.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "open", "object": "frame" }, "machineRoute": "hairness work open-frame", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/work", "id": "open-frame" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "effect" } } },
    { "id": "hairness.work.discuss", "summary": "Discuss one bounded frame without effects or artifact promotion.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "discuss" }, "machineRoute": "hairness work discuss", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/work", "id": "discuss" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.make-recap", "summary": "Produce a typed chat recap of active work without artifact promotion.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "make", "object": "recap" }, "machineRoute": "hairness work make-recap", "arguments": [], "resultId": "response", "operation": { "capability": "hairness/work", "id": "recap" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.save-recap", "summary": "Promote the latest compatible recap result as a SegmentDigest artifact.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "save", "object": "recap" }, "machineRoute": "hairness work save-recap", "arguments": [], "resultId": "artifact", "operation": { "capability": "hairness/work", "id": "recap" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "artifact" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.make-plan", "summary": "Draft an enriched typed work plan in chat without artifact promotion.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "make", "object": "plan" }, "machineRoute": "hairness work make-plan", "arguments": [], "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.save-plan", "summary": "Promote the latest compatible work-plan result as an artifact.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "save", "object": "plan" }, "machineRoute": "hairness work save-plan", "arguments": [], "resultId": "artifact", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "promotion": "artifact" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.show-next", "summary": "Show the next useful routes for the active work.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "next" }, "machineRoute": "hairness work show-next", "arguments": [], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "next", "promotion": "none" } } },
    { "id": "hairness.work.ask-next", "summary": "Ask the one next question that unblocks the active work.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "ask", "object": "next" }, "machineRoute": "hairness work ask-next", "arguments": [], "resultId": "dashboard", "operation": { "capability": "hairness/work", "id": "inspect" }, "instructions": "./commands/work.md", "fixed": { "controls": { "view": "question", "promotion": "none" } } },
    { "id": "hairness.work.plan-system-wire", "summary": "Draft a system wiring plan with explicit owner and compatibility controls.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "plan", "object": "system", "qualifiers": ["wire"] }, "machineRoute": "hairness work plan-system-wire", "arguments": [{ "name": "focus", "required": false }], "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "planKind": "system-wire", "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.plan-system-shape", "summary": "Draft a target-shape plan using the reshape-system controls.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "plan", "object": "system", "qualifiers": ["shape"] }, "machineRoute": "hairness work plan-system-shape", "arguments": [{ "name": "focus", "required": false }], "resultId": "response", "operation": { "capability": "hairness/work", "id": "plan" }, "instructions": "./commands/work.md", "fixed": { "controls": { "planKind": "system-shape", "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work.do-frame", "summary": "Act on one accepted frame through an explicit checkpoint.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "do", "object": "frame" }, "machineRoute": "hairness work do-frame", "arguments": [{ "name": "focus", "required": true }], "resultId": "default", "operation": { "capability": "hairness/work", "id": "act" }, "instructions": "./commands/work.md", "defaults": { "mode": "auto" }, "fixed": { "controls": { "promotion": "effect" } }, "overrides": ["mode", "budget"] },
    { "id": "hairness.work.do-plan", "summary": "Execute an accepted WorkPlan through bounded routes.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "do", "object": "plan" }, "machineRoute": "hairness work do-plan", "arguments": [{ "name": "plan", "required": true }], "resultId": "default", "operation": { "capability": "hairness/work", "id": "execute" }, "instructions": "./commands/work.md", "defaults": { "mode": "auto" }, "fixed": { "controls": { "promotion": "effect" } }, "overrides": ["mode", "budget"] }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/work-controls/work-state.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "mission", "activeSegmentId", "methodologyBinding", "segments", "frames", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "mission": { "anyOf": [{ "$ref": "#/$defs/mission" }, { "type": "null" }] },
    "activeSegmentId": { "type": ["string", "null"] },
    "methodologyBinding": { "type": ["string", "null"] },
    "controls": { "type": "object" },
    "segments": { "type": "array", "items": { "$ref": "#/$defs/segment" } },
    "frames": { "type": "array", "items": { "$ref": "#/$defs/frame" } },
    "updatedAt": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "constraints"],
      "properties": {
        "scope": { "enum": ["session", "segment", "frame", "operation"] },
        "constraints": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "entityRef": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": { "kind": { "type": "string" }, "id": { "type": "string" }, "revision": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$", "maxLength": 128 } }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target"],
      "properties": { "type": { "type": "string" }, "target": { "$ref": "#/$defs/entityRef" } }
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "summary", "status", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }, "summary": { "type": "string", "minLength": 1 },
        "status": { "enum": ["active", "closed"] }, "createdAt": { "type": "string" }, "updatedAt": { "type": "string" }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "missionId", "summary", "status", "boundary", "relations", "frames", "artifacts", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" }, "missionId": { "type": "string" }, "summary": { "type": "string", "minLength": 1 },
        "status": { "enum": ["active", "closed"] }, "boundary": { "$ref": "#/$defs/boundary" },
        "relations": { "type": "array", "items": { "$ref": "#/$defs/relation" } },
        "frames": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/entityRef" } },
        "controls": { "type": "object" },
        "digestArtifact": { "$ref": "#/$defs/entityRef" }, "createdAt": { "type": "string" }, "updatedAt": { "type": "string" }
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "segmentId", "summary", "posture", "status", "boundary", "artifacts", "sources", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" }, "segmentId": { "type": "string" }, "summary": { "type": "string", "minLength": 1 },
        "posture": { "enum": ["discuss", "recap", "plan", "act", "execute"] }, "status": { "enum": ["open", "closed"] },
        "boundary": { "$ref": "#/$defs/boundary" }, "controls": { "type": "object" }, "artifacts": { "type": "array", "items": { "$ref": "#/$defs/entityRef" } },
        "sources": { "type": "array", "items": { "$ref": "#/$defs/entityRef" } }, "createdAt": { "type": "string" }, "updatedAt": { "type": "string" }
      }
    }
  }
}

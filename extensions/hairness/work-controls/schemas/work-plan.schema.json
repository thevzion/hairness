{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["segmentId", "executionBoundary", "originalFrame", "framesConsidered", "coherence", "alreadyDone", "goal", "scope", "nonGoals", "targetShape", "ownershipChanges", "compatibility", "decisionBatch", "steps", "validation", "risks", "checkpoints", "openQuestions", "constraints"],
  "properties": {
    "segmentId": { "type": "string", "minLength": 1 },
    "executionBoundary": { "type": "string", "minLength": 1 },
    "originalFrame": { "type": ["string", "null"] },
    "framesConsidered": { "type": "array", "items": { "type": "string" } },
    "coherence": { "type": "string", "minLength": 1 },
    "alreadyDone": { "type": "array", "items": { "type": "string" } },
    "goal": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "nonGoals": { "type": "array", "items": { "type": "string" } },
    "targetShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "scope", "oldOwner", "targetOwner", "legacyKept", "legacyDeleted", "compatibility", "proof", "checkpoint"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "scope": { "type": "array", "items": { "type": "string" } },
        "oldOwner": { "type": ["string", "null"] },
        "targetOwner": { "type": ["string", "null"] },
        "legacyKept": { "type": "array", "items": { "type": "string" } },
        "legacyDeleted": { "type": "array", "items": { "type": "string" } },
        "compatibility": { "type": "array", "items": { "type": "string" } },
        "proof": { "type": "array", "items": { "type": "string" } },
        "checkpoint": { "type": ["string", "null"] }
      }
    },
    "ownershipChanges": { "type": "array", "items": { "type": "string" } },
    "compatibility": { "type": "array", "items": { "type": "string" } },
    "decisionBatch": { "type": "array", "items": { "type": "string" } },
    "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "validation": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "checkpoints": { "type": "array", "items": { "type": "string" } },
    "openQuestions": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}

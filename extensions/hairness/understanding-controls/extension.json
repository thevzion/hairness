{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/understanding-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Composable map, explain and compare operations.",
  "category": "cognition",
  "tags": ["mapping", "explanation"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/understanding.json"],
  "dependencies": ["hairness/presentation-controls"],
  "commands": [
    { "namespace": "map", "actions": ["request"] },
    { "namespace": "explain", "actions": ["request"] },
    { "namespace": "compare", "actions": ["request"] }
  ],
  "commandSurfaces": [
    { "id": "hairness.understanding.show-structure", "summary": "Show the relationships needed to understand one focus.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "structure" }, "machineRoute": "hairness map", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/understanding", "id": "map" }, "instructions": "./commands/understanding.md", "fixed": { "controls": { "promotion": "none", "view": "structure" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.understanding.compare-options", "summary": "Compare explicit options and their tradeoffs without manufacturing a decision.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "compare", "object": "options" }, "machineRoute": "hairness compare", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/understanding", "id": "compare" }, "instructions": "./commands/understanding.md", "fixed": { "controls": { "promotion": "none", "view": "comparison" } }, "acceptsModifiers": ["hairness.presentation"] }
  ]
}

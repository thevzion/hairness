    { "id": "explain", "class": "derive", "summary": "Clarify one concept from available meaning and proof.", "result": { "schema": "ContextPacket", "disposition": "response" }, "sources": [], "effects": [], "routes": ["inline", "worker"], "acceptsModifiers": ["hairness.presentation"] },
    { "id": "compare", "class": "derive", "summary": "Put explicit alternatives and tradeoffs in tension.", "result": { "schema": "ContextPacket", "disposition": "response" }, "sources": [], "effects": [], "routes": ["inline", "worker"], "acceptsModifiers": ["hairness.presentation"] }

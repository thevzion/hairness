  "commandSurfaces": [
    { "id": "hairness.codebase", "summary": "Guide registered codebase inspection, mounts and map routes.", "classification": "primary", "surface": "namespace", "machineRoute": "hairness codebase", "arguments": [{ "name": "action", "required": false }, { "name": "id", "required": false }], "resultId": "default", "operation": { "capability": "hairness/codebase", "id": "inspect" }, "instructions": "./commands/hairness-codebase.md" }
  ]

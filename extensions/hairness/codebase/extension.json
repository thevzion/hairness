{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/codebase",
  "version": "0.2.0-alpha.0",
  "module": "./index.mjs",
  "dependencies": ["hairness/git"],
  "services": ["inspect"],
  "contributes": ["attention", "session-opening"],
  "artifactSchemas": [
    { "type": "codebase-map", "schema": "./schemas/map.schema.json" },
    { "type": "entrypoint-map", "schema": "./schemas/map.schema.json" },
    { "type": "system-map", "schema": "./schemas/map.schema.json" }
  ],
  "commands": [{ "namespace": "codebase", "actions": ["list", "show", "doctor", "add", "mount", "unmount", "remove", "map", "entrypoint", "system"] }],
  "providerCommands": [
    { "id": "hairness.codebase", "name": "hairness-codebase", "summary": "Inspect or route work for a registered codebase.", "kind": "capability", "classification": "specialized", "command": "hairness codebase", "arguments": [{ "name": "action", "required": false }, { "name": "id", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "capabilities": ["codebase"], "instructions": "./commands/hairness-codebase.md" },
    { "id": "hairness.map-codebase", "name": "hairness-map-codebase", "summary": "Produce or refresh one bounded codebase digest.", "kind": "preset", "classification": "accelerator", "command": "hairness codebase map", "arguments": [{ "name": "id", "required": true }], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/codebase", "artifactType": "codebase-map" }, "capabilities": ["codebase", "mapping"], "instructions": "./commands/hairness-map-codebase.md", "defaults": { "mode": "auto", "budget": "balanced" }, "overrides": ["mode", "budget"] },
    { "id": "hairness.map-entrypoint", "name": "hairness-map-entrypoint", "summary": "Map one runtime or product entrypoint in a codebase.", "kind": "preset", "classification": "accelerator", "command": "hairness codebase entrypoint", "arguments": [{ "name": "id", "required": true }, { "name": "entrypoint", "required": true }], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/codebase", "artifactType": "entrypoint-map" }, "capabilities": ["codebase", "mapping"], "instructions": "./commands/hairness-map-entrypoint.md", "defaults": { "mode": "auto" }, "overrides": ["mode", "budget"] },
    { "id": "hairness.map-system", "name": "hairness-map-system", "summary": "Map relationships across the registered codebase system.", "kind": "preset", "classification": "accelerator", "command": "hairness codebase system", "arguments": [], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/codebase", "artifactType": "system-map" }, "capabilities": ["codebase", "mapping"], "instructions": "./commands/hairness-map-system.md", "defaults": { "mode": "auto", "budget": "deep" }, "overrides": ["mode", "budget"] }
  ]
}

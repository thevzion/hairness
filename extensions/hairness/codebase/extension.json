{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/codebase",
  "version": "0.2.0-alpha.0",
  "summary": "Codebase contracts, mounts, inspection and typed maps.",
  "category": "ecosystem",
  "tags": ["codebase", "mapping"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/codebase.json"],
  "dependencies": ["hairness/sources", "hairness/presentation-controls"],
  "services": ["inspect"],
  "contributes": ["attention", "session-opening", "onboarding"],
  "artifactSchemas": [
    { "type": "codebase-map", "schema": "./schemas/map.schema.json" },
    { "type": "entrypoint-map", "schema": "./schemas/map.schema.json" },
    { "type": "system-map", "schema": "./schemas/map.schema.json" }
  ],
  "commands": [{ "namespace": "codebase", "actions": ["list", "show", "doctor", "add", "mount", "unmount", "remove", "map", "entrypoint", "system"] }],
  "providerCommands": [
    { "id": "hairness.codebase", "name": "hairness-codebase", "summary": "Inspect or route work for a registered codebase.", "kind": "capability", "classification": "specialized", "command": "hairness codebase", "arguments": [{ "name": "action", "required": false }, { "name": "id", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "operation": { "capability": "hairness/codebase", "id": "inspect" }, "instructions": "./commands/hairness-codebase.md" },
    { "id": "hairness.map-codebase", "name": "hairness-map-codebase", "summary": "Produce a bounded codebase, entrypoint, or system map.", "kind": "preset", "classification": "accelerator", "command": "hairness codebase map", "arguments": [{ "name": "id", "required": false }, { "name": "focus", "required": false }], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/codebase", "artifactType": "codebase-map" }, "operation": { "capability": "hairness/codebase", "id": "map" }, "instructions": "./commands/hairness-map-codebase.md", "defaults": { "mode": "auto", "budget": "balanced", "focus": "codebase" }, "overrides": ["mode", "budget", "focus"], "acceptsModifiers": ["hairness.presentation"] }
  ]
}

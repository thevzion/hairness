{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/codebase",
  "version": "0.2.0-alpha.0",
  "summary": "Codebase contracts, mounts, inspection and typed maps.",
  "category": "ecosystem",
  "tags": ["codebase", "mapping"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/codebase.json"],
  "dependencies": ["hairness/sources", "hairness/presentation-controls"],

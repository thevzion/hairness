{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/workframes",
  "version": "0.2.0-alpha.0",
  "module": "./index.mjs",
  "dependencies": ["hairness/cockpit"],
  "services": ["state", "set-boundary"],
  "contributes": ["session-opening"],
  "relationTypes": ["continues", "depends-on", "informs", "supersedes", "blocks", "related-to"],
  "commands": [{ "namespace": "work", "actions": ["status", "history", "trace", "resume", "mission", "segment", "frame", "method", "discuss", "new-frame", "map", "recap", "propose", "plan", "act", "execute"] }],
  "artifactSchemas": [
    { "type": "segment-digest", "schema": "./schemas/segment-digest.schema.json" },
    { "type": "work-plan", "schema": "./schemas/work-plan.schema.json" }
  ],
  "providerCommands": [
    { "id": "hairness.workframes", "name": "hairness-workframes", "summary": "Inspect and steer the persistent Hairness work trajectory.", "kind": "capability", "classification": "specialized", "command": "hairness work status", "arguments": [{ "name": "action", "required": false }], "result": { "schema": "WorkframeState", "disposition": "run-only" }, "capabilities": ["work"], "instructions": "./commands/workframes.md" },
    { "id": "hairness.work-method", "name": "hairness-work-method", "summary": "Select or inspect the methodology binding for the active trajectory.", "kind": "capability", "classification": "specialized", "command": "hairness work method show", "arguments": [{ "name": "action", "required": false }, { "name": "binding", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "capabilities": ["work"], "instructions": "./commands/workframes.md", "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-discuss", "name": "hairness-work-discuss", "summary": "Discuss one bounded frame without effects.", "kind": "preset", "classification": "accelerator", "command": "hairness work discuss", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "capabilities": ["work"], "instructions": "./commands/workframes.md", "fixed": { "mode": "discuss" }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-new-frame", "name": "hairness-work-new-frame", "summary": "Open one new frame in the active segment.", "kind": "preset", "classification": "accelerator", "command": "hairness work new-frame", "arguments": [{ "name": "focus", "required": true }], "result": { "schema": "WorkFrame", "disposition": "run-only" }, "capabilities": ["work"], "instructions": "./commands/workframes.md" },
    { "id": "hairness.work-map", "name": "hairness-work-map", "summary": "Map the active segment without introducing new scope.", "kind": "preset", "classification": "accelerator", "command": "hairness work map", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "capabilities": ["work", "mapping"], "instructions": "./commands/workframes.md", "defaults": { "mode": "auto", "budget": "balanced" }, "overrides": ["mode", "budget"], "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-recap", "name": "hairness-work-recap", "summary": "Reduce the active segment into decisions, evidence and open edges.", "kind": "preset", "classification": "accelerator", "command": "hairness work recap", "arguments": [], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/workframes", "artifactType": "segment-digest" }, "capabilities": ["work"], "instructions": "./commands/workframes.md", "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-propose", "name": "hairness-work-propose", "summary": "Produce one recommended direction inside the active frame.", "kind": "preset", "classification": "accelerator", "command": "hairness work propose", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "capabilities": ["work"], "instructions": "./commands/workframes.md", "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-plan", "name": "hairness-work-plan", "summary": "Produce a typed work plan from accepted segment decisions.", "kind": "preset", "classification": "accelerator", "command": "hairness work plan", "arguments": [], "result": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/workframes", "artifactType": "work-plan" }, "capabilities": ["work", "planning"], "instructions": "./commands/workframes.md", "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.work-act", "name": "hairness-work-act", "summary": "Act on one accepted frame through an explicit checkpoint.", "kind": "preset", "classification": "accelerator", "command": "hairness work act", "arguments": [{ "name": "focus", "required": true }], "result": { "schema": "ChangeReceipt", "disposition": "effect" }, "capabilities": ["work", "execution"], "instructions": "./commands/workframes.md", "defaults": { "mode": "auto" }, "overrides": ["mode", "budget"] },
    { "id": "hairness.work-execute", "name": "hairness-work-execute", "summary": "Execute an accepted WorkPlan through bounded routes.", "kind": "preset", "classification": "accelerator", "command": "hairness work execute", "arguments": [{ "name": "plan", "required": true }], "result": { "schema": "ContextPacket", "disposition": "effect" }, "capabilities": ["work", "execution"], "instructions": "./commands/workframes.md", "defaults": { "mode": "auto" }, "overrides": ["mode", "budget"] }
  ]
}

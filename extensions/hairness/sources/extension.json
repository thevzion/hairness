{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/sources",
  "version": "0.2.0-alpha.0",
  "summary": "Read-only source drivers, evidence, redaction and freshness.",
  "category": "ecosystem",
  "tags": ["sources", "evidence"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/sources.json"],
  "dependencies": [],
  "services": ["list", "doctor", "read"],
  "contributes": ["session-opening", "onboarding"],
  "sourceDrivers": [
    "./drivers/git/driver.json",
    "./drivers/github/driver.json",
    "./drivers/npm/driver.json",
    "./drivers/jira/driver.json",
    "./drivers/gitlab/driver.json",
    "./drivers/aws/driver.json"
  ],
  "commands": [{ "namespace": "source", "actions": ["list", "doctor", "read"] }],
  "commandSurfaces": [
    { "id": "hairness.source", "summary": "Guide deterministic source inspection and read-only proof routes.", "classification": "primary", "surface": "namespace", "machineRoute": "hairness source", "arguments": [{ "name": "action", "required": false }, { "name": "source", "required": false }], "resultId": "default", "operation": { "capability": "hairness/sources", "id": "list" }, "instructions": "./commands/sources.md" },
    { "id": "hairness.sources.check", "summary": "Resolve proof gaps using selected sources before broader discovery.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "check", "object": "sources" }, "machineRoute": "hairness source doctor", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/sources", "id": "doctor" }, "instructions": "./commands/sources.md", "fixed": { "controls": { "promotion": "none" } } }
  ]
}

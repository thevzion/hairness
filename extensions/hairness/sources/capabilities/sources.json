{
  "$schema": "../../../../schemas/capability.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/sources",
  "owner": "hairness/sources",
  "version": "0.2.0-alpha.0",
  "summary": "Produce current typed evidence through selected read-only source drivers.",
  "operations": [
    {
      "id": "list",
      "class": "observe",
      "summary": "List selected source drivers and operations.",
      "sources": [],
      "effects": [],
      "routes": [
        "deterministic"
      ],
      "acceptsModifiers": [],
      "results": [
        {
          "id": "default",
          "contract": {
            "schema": "ContextPacket",
            "disposition": "response"
          }
        },
        {
          "id": "evidence",
          "contract": {
            "schema": "SourceEvidence",
            "disposition": "response"
          }
        }
      ],
      "defaultResult": "default"
    },
    {
      "id": "doctor",
      "class": "observe",
      "summary": "Verify selected source drivers and required executables.",
      "sources": [],
      "effects": [],
      "routes": [
        "deterministic"
      ],
      "acceptsModifiers": [],
      "results": [
        {
          "id": "default",
          "contract": {
            "schema": "DoctorReport",
            "disposition": "response"
          }
        }
      ],
      "defaultResult": "default"
    },
    {
      "id": "read",
      "class": "observe",
      "summary": "Read one declared operation as current SourceEvidence.",
      "sources": [],
      "effects": [],
      "routes": [
        "deterministic"
      ],
      "acceptsModifiers": [],
      "results": [
        {
          "id": "default",
          "contract": {
            "schema": "SourceEvidence",
            "disposition": "response"
          }
        }
      ],
      "defaultResult": "default"
    }
  ]
}

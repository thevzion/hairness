    { "id": "doctor", "class": "observe", "summary": "Verify selected source drivers and required executables.", "result": { "schema": "DoctorReport", "disposition": "response" }, "sources": [], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] },
    { "id": "read", "class": "observe", "summary": "Read one declared operation as current SourceEvidence.", "result": { "schema": "SourceEvidence", "disposition": "response" }, "sources": [], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] }

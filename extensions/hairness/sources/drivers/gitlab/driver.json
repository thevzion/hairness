{
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "gitlab",
  "transport": "glab",
  "executable": "glab",
  "module": "./index.mjs",
  "operations": [
    { "id": "identity", "access": "read", "summary": "Verify the local GitLab CLI identity." },
    { "id": "project", "access": "read", "summary": "Read one GitLab project." },
    { "id": "mr", "access": "read", "summary": "Read one merge request." },
    { "id": "discussions", "access": "read", "summary": "Read merge request discussions." },
    { "id": "approvals", "access": "read", "summary": "Read merge request approvals." },
    { "id": "pipelines", "access": "read", "summary": "Read project pipelines." }
  ]
}

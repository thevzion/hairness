    { "id": "propose", "class": "derive", "summary": "Recommend one direction with tradeoff, risk and confidence.", "result": { "schema": "ContextPacket", "disposition": "response" }, "sources": [], "effects": [], "routes": ["inline", "worker"], "acceptsModifiers": ["hairness.creative", "hairness.presentation"] }
  ]

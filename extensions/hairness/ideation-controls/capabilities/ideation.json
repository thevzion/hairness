{
  "$schema": "../../../../schemas/capability.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/ideation",
  "owner": "hairness/ideation-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Explore candidate directions and converge toward an explicit proposal.",
  "operations": [
    {
      "id": "ideate",
      "class": "derive",
      "summary": "Open several candidate directions without treating them as decisions.",
      "sources": [],
      "effects": [],
      "routes": [
        "inline",
        "worker"
      ],
      "acceptsModifiers": [
        "hairness.creative",
        "hairness.presentation"
      ],
      "results": [
        {
          "id": "default",
          "contract": {
            "schema": "ContextPacket",
            "disposition": "response"
          }
        }
      ],
      "defaultResult": "default"
    },
    {
      "id": "propose",
      "class": "derive",
      "summary": "Recommend one direction with tradeoff, risk and confidence.",
      "sources": [],
      "effects": [],
      "routes": [
        "inline",
        "worker"
      ],
      "acceptsModifiers": [
        "hairness.creative",
        "hairness.presentation"
      ],
      "results": [
        {
          "id": "default",
          "contract": {
            "schema": "ContextPacket",
            "disposition": "response"
          }
        }
      ],
      "defaultResult": "default"
    }
  ]
}

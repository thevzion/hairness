{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/ideation-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Divergent, lateral and convergent ideation controls.",
  "category": "cognition",
  "tags": ["ideation", "creative"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/ideation.json"],
  "dependencies": ["hairness/presentation-controls"],
  "intentModifiers": [{ "id": "hairness.creative", "argument": "creative", "values": ["divergent", "lateral", "convergent"], "default": "divergent" }],
  "commands": [
    { "namespace": "ideate", "actions": ["request"] },
    { "namespace": "propose", "actions": ["request"] }
  ],
  "providerCommands": [
    { "id": "hairness.x.propose", "name": "hairness-x-propose", "summary": "Recommend one direction with its tradeoff, risk and confidence.", "kind": "preset", "classification": "accelerator", "surface": "intent", "command": "hairness propose", "arguments": [{ "name": "focus", "required": false }], "result": { "schema": "ContextPacket", "disposition": "response" }, "resultId": "default", "operation": { "capability": "hairness/ideation", "id": "propose" }, "instructions": "./commands/ideation.md", "fixed": { "controls": { "persistence": "none" } }, "acceptsModifiers": ["hairness.creative", "hairness.presentation"] }
  ]
}

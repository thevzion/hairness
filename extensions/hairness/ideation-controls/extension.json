{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/ideation-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Divergent, lateral and convergent ideation controls.",
  "category": "cognition",
  "tags": ["ideation", "creative"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/ideation.json"],
  "dependencies": ["hairness/presentation-controls"],
  "intentModifiers": [{ "id": "hairness.creative", "argument": "creative", "values": ["divergent", "lateral", "convergent"], "default": "divergent" }],
  "commands": [
    { "namespace": "ideate", "actions": ["request"] },
    { "namespace": "propose", "actions": ["request"] }
  ],
  "commandSurfaces": [
    { "id": "hairness.ideation.ideate", "summary": "Open several candidate directions without treating them as decisions.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "ideate" }, "machineRoute": "hairness ideate", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/ideation", "id": "ideate" }, "instructions": "./commands/ideation.md", "fixed": { "controls": { "creative": "divergent", "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.ideation.propose", "summary": "Recommend one direction with its tradeoff, risk and confidence.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "propose" }, "machineRoute": "hairness propose", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/ideation", "id": "propose" }, "instructions": "./commands/ideation.md", "fixed": { "controls": { "creative": "convergent", "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] },
    { "id": "hairness.ideation.propose-creative", "summary": "Recommend one lateral, non-obvious direction with tradeoff, risk and confidence.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "propose", "object": "creative" }, "machineRoute": "hairness propose", "arguments": [{ "name": "focus", "required": false }], "resultId": "default", "operation": { "capability": "hairness/ideation", "id": "propose" }, "instructions": "./commands/ideation.md", "fixed": { "controls": { "creative": "lateral", "promotion": "none" } }, "acceptsModifiers": ["hairness.presentation"] }
  ]
}

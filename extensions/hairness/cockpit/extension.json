{
  "$schema": "../../../schemas/extension.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/cockpit",
  "version": "0.2.0-alpha.0",
  "summary": "Main-session routing, help, onboarding and compact attention.",
  "category": "interaction",
  "tags": ["main-session", "help", "onboarding"],
  "maturity": "official",
  "readme": "./README.md",
  "module": "./index.mjs",
  "capabilities": ["./capabilities/cockpit.json"],
  "dependencies": [],
  "contributes": ["attention", "agent-guidance", "session-opening", "session-renderer", "provider-hooks"],
  "agentGuidance": [{ "id": "agent-contract", "source": "./guidance/agent-contract.md", "targets": ["AGENTS.md", "CLAUDE.md"] }],
  "commands": [{ "namespace": "wake-up", "actions": ["show"] }, { "namespace": "topics", "actions": ["show"] }, { "namespace": "help", "actions": ["show"] }],
  "commandSurfaces": [
    { "id": "hairness.root", "summary": "Route one intention through the active Hairness distribution.", "classification": "primary", "surface": "bridge", "machineRoute": "hairness help", "arguments": [], "instructions": "./commands/hairness.md" },
    { "id": "hairness.help", "summary": "Explain the active human command surface and exact host invocations.", "classification": "primary", "surface": "namespace", "machineRoute": "hairness help", "arguments": [], "resultId": "default", "operation": { "capability": "hairness/cockpit", "id": "help" }, "instructions": "./commands/hairness-help.md" },
    { "id": "hairness.onboarding", "summary": "Continue deterministic local onboarding one question at a time.", "classification": "specialized", "surface": "specialized", "machineRoute": "hairness onboarding next", "arguments": [], "resultId": "default", "operation": { "capability": "hairness/cockpit", "id": "onboarding" }, "instructions": "./commands/hairness-onboarding.md" },
    { "id": "hairness.wake-up", "summary": "Show current attention, limits, and the next useful route.", "classification": "primary", "surface": "specialized", "machineRoute": "hairness wake-up", "arguments": [], "resultId": "default", "operation": { "capability": "hairness/cockpit", "id": "wake-up" }, "entryPolicy": "opening-first", "instructions": "./commands/hairness-wake-up.md" },
    { "id": "hairness.cockpit.show-topics", "summary": "Show recoverable subjects across sessions with their next read-only route.", "classification": "accelerator", "surface": "intent", "lexeme": { "verb": "show", "object": "topics" }, "machineRoute": "hairness topics", "arguments": [], "resultId": "default", "operation": { "capability": "hairness/cockpit", "id": "attention" }, "instructions": "./commands/hairness-show-topics.md", "fixed": { "controls": { "view": "topics", "promotion": "none" } } }
  ]
}

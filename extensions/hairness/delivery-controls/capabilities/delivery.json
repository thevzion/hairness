{
  "$schema": "../../../../schemas/capability.schema.json",
  "schemaVersion": 2,
  "protocolVersion": "0.2",
  "id": "hairness/delivery",
  "owner": "hairness/delivery-controls",
  "version": "0.2.0-alpha.0",
  "summary": "Model policy-driven change and release delivery without owning provider effects.",
  "operations": [
    { "id": "inspect", "class": "observe", "summary": "Inspect delivery plans and receipts.", "results": [{ "id": "default", "contract": { "schema": "DeliveryState", "disposition": "run-only" } }], "defaultResult": "default", "sources": [], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] },
    { "id": "brief", "class": "derive", "summary": "Draft a delivery brief in chat without promoting it.", "inputSchema": "./schemas/delivery-brief-input.schema.json", "results": [{ "id": "response", "contract": { "schema": "ContextPacket", "disposition": "response" } }], "defaultResult": "response", "sources": [], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] },
    { "id": "advance", "class": "derive", "summary": "Preview exactly the next delivery boundary without performing it.", "results": [{ "id": "response", "contract": { "schema": "ContextPacket", "disposition": "response" } }], "defaultResult": "response", "sources": ["git", "github", "npm"], "effects": [], "routes": ["deterministic"], "acceptsModifiers": [] },
    { "id": "execute", "class": "effect", "summary": "Execute one explicitly checkpointed delivery boundary.", "results": [{ "id": "default", "contract": { "schema": "ChangeReceipt", "disposition": "effect" } }], "defaultResult": "default", "sources": ["git", "github", "npm"], "effects": ["filesystem:write", "git:branch", "git:commit", "git:push", "git:tag", "github:pull-request", "github:merge", "github:release", "npm:publish"], "routes": ["worker", "external"], "acceptsModifiers": [] },
    { "id": "release-candidate", "class": "derive", "summary": "Produce a typed release candidate and launch kit from accepted receipts.", "results": [{ "id": "default", "contract": { "schema": "ArtifactEnvelope", "disposition": "artifact", "artifactOwner": "hairness/delivery-controls", "artifactType": "release-candidate" } }], "defaultResult": "default", "sources": [], "effects": [], "routes": ["worker"], "acceptsModifiers": [] }
  ]
}

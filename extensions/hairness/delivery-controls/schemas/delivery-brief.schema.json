{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/delivery-controls/delivery-brief.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "subject", "type", "outcome", "acceptance", "scope", "nonGoals", "releaseImpact", "repository", "repositoryRef", "base", "branch", "checks", "risks", "confidence", "policyDigest", "createdAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "outcome": { "type": "string", "minLength": 1 },
    "acceptance": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "scope": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "nonGoals": { "type": "array", "items": { "type": "string" } },
    "releaseImpact": { "enum": ["user", "internal", "none"] },
    "repository": { "type": "string", "minLength": 1 },
    "repositoryRef": { "$ref": "#/$defs/RepositoryRef" },
    "base": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "checks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "risks": { "type": "array", "items": { "type": "string" } },
    "confidence": { "enum": ["low", "medium", "high"] },
    "policyDigest": { "type": "string", "pattern": "^sha256:" },
    "createdAt": { "type": "string" }
  },
  "$defs": {
    "RepositoryRef": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "workspace" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "id"], "properties": { "kind": { "const": "codebase" }, "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }, "checkout": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } } }
      ]
    }
  }
}

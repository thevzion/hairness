{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/delivery-controls/delivery-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "repository", "baseBranch", "branchTypes", "branchPattern", "merge", "requiredChecks", "evidenceMaxAgeMinutes", "release"],
  "properties": {
    "profile": { "const": "github-flow" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "baseBranch": { "type": "string", "minLength": 1 },
    "branchTypes": { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }, "minItems": 1, "uniqueItems": true },
    "branchPattern": { "type": "string", "minLength": 1 },
    "merge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "deleteBranch", "linearHistory", "resolveConversations"],
      "properties": {
        "method": { "const": "squash" },
        "deleteBranch": { "type": "boolean" },
        "linearHistory": { "type": "boolean" },
        "resolveConversations": { "type": "boolean" }
      }
    },
    "requiredChecks": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
    "evidenceMaxAgeMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "registry", "versionSource", "prereleaseTag", "gitTagFormat", "githubRelease", "bootstrapBaseline"],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "format": "uri" },
        "versionSource": { "type": "string", "minLength": 1 },
        "prereleaseTag": { "type": "string", "minLength": 1 },
        "gitTagFormat": { "type": "string", "minLength": 1 },
        "githubRelease": { "enum": ["prerelease", "release", "none"] },
        "bootstrapBaseline": { "type": ["string", "null"] }
      }
    }
  }
}

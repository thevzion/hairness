{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/delivery-controls/release-candidate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["planId", "version", "changes", "checks", "limitations", "launchKit"],
  "properties": {
    "planId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "changes": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "launchKit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["messages", "audiences", "faq", "drafts", "order"],
      "properties": {
        "messages": { "type": "array", "items": { "type": "string" } },
        "audiences": { "type": "array", "items": { "type": "string" } },
        "faq": { "type": "array", "items": { "type": "string" } },
        "drafts": { "type": "object" },
        "order": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

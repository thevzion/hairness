{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/extensions/delivery-controls/release-candidate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["planId", "policyDigest", "checkoutContext", "package", "commit", "changes", "checks", "tarball", "dryRun", "limitations", "observedAt"],
  "properties": {
    "planId": { "type": "string", "minLength": 1 },
    "policyDigest": { "type": "string", "pattern": "^sha256:" },
    "checkoutContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handleRef", "policyDigest"],
      "properties": {
        "handleRef": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "digest"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "digest": { "type": "string", "pattern": "^sha256:" }
          }
        },
        "policyDigest": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "registry", "distTag"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "minLength": 1 },
        "distTag": { "type": "string", "minLength": 1 }
      }
    },
    "commit": { "type": "string", "minLength": 7 },
    "changes": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tarball": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "integrity"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:" },
        "integrity": { "type": "string", "minLength": 1 }
      }
    },
    "dryRun": { "type": "string", "minLength": 1 },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "observedAt": { "type": "string" }
  }
}

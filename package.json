{
  "name": "@hairness/cli",
  "version": "0.4.0-alpha.0",
  "description": "Source-owned agentic assets for any agent runtime.",
  "keywords": [
    "ai-agents",
    "agentic-assets",
    "ai-harness",
    "provider-agnostic",
    "developer-tools",
    "codex",
    "claude-code"
  ],
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thevzion/hairness.git"
  },
  "homepage": "https://github.com/thevzion/hairness#readme",
  "bugs": {
    "url": "https://github.com/thevzion/hairness/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "type": "module",
  "bin": {
    "hairness": "bin/hairness.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/",
    "docs/reference.md",
    "assets/onboarding/",
    "assets/scratch/",
    "schemas/v4/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "check": "node scripts/check.mjs",
    "conformance": "node scripts/conformance.mjs",
    "test:node22": "npx -y node@22 scripts/run-tests.mjs",
    "test:node24": "npx -y node@24 scripts/run-tests.mjs",
    "check:providers": "node scripts/check-providers.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check:lab": "node scripts/lab-dogfood.mjs",
    "launch:render": "node scripts/render-launch-assets.mjs",
    "release:pack": "node scripts/release-packages.mjs",
    "release:dry-run": "node scripts/release-publish.mjs --dry-run"
  },
  "dependencies": {
    "ajv": "8.20.0"
  }
}

{
  "name": "@hairness/cli",
  "version": "0.2.0-alpha.0",
  "description": "Provider-agnostic harness that equips native AI agents to operate across your codebases, tools, and workflows.",
  "keywords": [
    "ai-agents",
    "agentic-ai",
    "agentic-systems",
    "ai-harness",
    "provider-agnostic",
    "developer-tools",
    "cli",
    "automation",
    "human-in-the-loop",
    "multi-repo",
    "codex",
    "claude-code"
  ],
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thevzion/hairness.git"
  },
  "homepage": "https://github.com/thevzion/hairness#readme",
  "bugs": {
    "url": "https://github.com/thevzion/hairness/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "type": "module",
  "bin": {
    "hairness": "bin/hairness.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "bin/",
    "catalog/",
    "docs/compatibility.md",
    "docs/extensions/catalog.md",
    "docs/known-limitations.md",
    "docs/releases/0.2.0-alpha.0.md",
    "docs/releasing.md",
    "extensions/hairness/",
    "migrations/",
    "schemas/",
    "scripts/check-commits.mjs",
    "scripts/check-pack.mjs",
    "scripts/generate-extension-catalog.mjs",
    "scripts/check-providers.mjs",
    "scripts/check.mjs",
    "scripts/conformance.mjs",
    "scripts/extension-ownership-gate.mjs",
    "scripts/impact-gate.mjs",
    "scripts/run-tests.mjs",
    "src/",
    "templates/",
    "LICENSE",
    "README.md",
    "hairness.json"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "check": "node scripts/check.mjs",
    "conformance": "node scripts/conformance.mjs",
    "test:node22": "npx -y node@22 scripts/run-tests.mjs",
    "test:node24": "npx -y node@24 scripts/run-tests.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "check:impact": "node scripts/impact-gate.mjs",
    "check:providers": "node scripts/check-providers.mjs",
    "check:commits": "node scripts/check-commits.mjs",
    "check:ownership": "node scripts/extension-ownership-gate.mjs",
    "catalog": "node scripts/generate-extension-catalog.mjs",
    "check:catalog": "node scripts/generate-extension-catalog.mjs --check"
  },
  "dependencies": {
    "ajv": "8.20.0"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/home/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/home/v1alpha1" },
    "kind": { "const": "Home" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": { "id": { "$ref": "#/$defs/id" } }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "providers", "extensions", "targets", "overlay"],
      "properties": {
        "language": { "type": "string", "minLength": 2, "maxLength": 35 },
        "providers": { "type": "array", "uniqueItems": true, "minItems": 1, "items": { "enum": ["codex", "claude"] } },
        "extensions": { "type": "array", "uniqueItems": true, "minItems": 1, "items": { "$ref": "#/$defs/id" } },
        "targets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind"],
            "properties": { "id": { "$ref": "#/$defs/id" }, "kind": { "const": "git" } }
          }
        },
        "overlay": {
          "type": "object",
          "additionalProperties": false,
          "required": ["git", "snapshot"],
          "properties": { "git": { "type": "boolean" }, "snapshot": { "enum": ["boundary", "manual"] } }
        }
      }
    }
  },
  "$defs": { "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" } }
}

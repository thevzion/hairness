{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/extension/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/extension/v1alpha1" },
    "kind": { "const": "Extension" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "summary"],
      "properties": { "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" }, "version": { "type": "string" }, "summary": { "type": "string", "minLength": 1 } }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provides", "requires", "recipes", "adapters", "schemas", "gates", "onboarding", "tests"],
      "properties": {
        "provides": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "requires": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "recipes": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } },
        "adapters": { "type": "array", "items": { "$ref": "#/$defs/adapter" } },
        "schemas": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } },
        "gates": { "type": "array", "items": { "$ref": "#/$defs/gate" } },
        "onboarding": { "type": "array", "items": { "$ref": "#/$defs/onboarding" } },
        "tests": { "type": "array", "items": { "$ref": "#/$defs/fileEntry" } }
      }
    }
  },
  "$defs": {
    "fileEntry": { "type": "object", "additionalProperties": false, "required": ["id", "path"], "properties": { "id": { "type": "string" }, "path": { "type": "string" }, "summary": { "type": "string" }, "capability": { "type": "string" } } },
    "adapter": { "type": "object", "additionalProperties": false, "required": ["id", "mode", "path"], "properties": { "id": { "type": "string" }, "mode": { "enum": ["observe", "derive", "effect"] }, "path": { "type": "string" }, "capability": { "type": "string" } } },
    "gate": { "type": "object", "additionalProperties": false, "required": ["id", "stage"], "properties": { "id": { "type": "string" }, "stage": { "enum": ["after-implementation", "before-publish-pr", "before-merge", "after-merge"] }, "adapter": { "type": "string" } } },
    "onboarding": { "type": "object", "additionalProperties": false, "required": ["id", "question"], "properties": { "id": { "type": "string" }, "question": { "type": "string" }, "when": { "type": "object" }, "explanation": { "type": "string" } } }
  }
}

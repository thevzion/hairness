{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/receipt/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/receipt/v1alpha1" },
    "kind": { "const": "Receipt" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "createdAt"], "properties": { "id": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
    "spec": { "type": "object", "additionalProperties": false, "required": ["checkpoint", "operation", "target", "outcome", "result"], "properties": { "checkpoint": { "type": "string" }, "operation": { "type": "string" }, "target": { "type": "object" }, "outcome": { "enum": ["succeeded", "partial", "unknown", "failed"] }, "result": {} } }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/checkpoint/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/checkpoint/v1alpha1" },
    "kind": { "const": "Checkpoint" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "createdAt"], "properties": { "id": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
    "spec": { "type": "object", "additionalProperties": false, "required": ["operation", "mode", "adapter", "target", "inputsDigest", "evidenceDigest", "policyDigest", "status"], "properties": { "operation": { "type": "string" }, "mode": { "const": "effect" }, "adapter": { "type": "string" }, "target": { "type": "object" }, "inputsDigest": { "$ref": "#/$defs/digest" }, "evidenceDigest": { "$ref": "#/$defs/digest" }, "policyDigest": { "$ref": "#/$defs/digest" }, "status": { "enum": ["prepared", "consumed"] } } }
  },
  "$defs": { "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" } }
}

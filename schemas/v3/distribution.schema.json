{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/distribution/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/distribution/v1alpha1" },
    "kind": { "const": "Distribution" },
    "metadata": { "type": "object", "additionalProperties": false, "required": ["id", "version", "summary"], "properties": { "id": { "$ref": "#/$defs/id" }, "version": { "$ref": "#/$defs/semver" }, "summary": { "type": "string", "minLength": 1 } } },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extensions"],
      "properties": {
        "extensions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "defaults": { "type": "object" },
        "policies": { "type": "array", "items": { "type": "string" } },
        "onboarding": { "type": "array", "items": { "type": "object" } }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" }
  }
}

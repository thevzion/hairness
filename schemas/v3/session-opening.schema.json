{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/session-opening/v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "home", "instruction", "onboarding", "scratch", "targets", "commands", "limits", "routes"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/home/v1alpha1" },
    "kind": { "const": "SessionOpening" },
    "home": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "language", "providers"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "language": { "type": "string", "minLength": 2, "maxLength": 35 },
        "providers": { "type": "array", "uniqueItems": true, "minItems": 1, "items": { "enum": ["codex", "claude"] } }
      }
    },
    "instruction": { "type": "string", "minLength": 1 },
    "onboarding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": { "status": { "type": "string", "minLength": 1 } }
    },
    "scratch": {
      "anyOf": [
        { "type": "null" },
        { "type": "object", "additionalProperties": false, "required": ["id"], "properties": { "id": { "$ref": "#/$defs/id" } } }
      ]
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "bound", "head"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "bound": { "type": "boolean" },
          "head": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }
        }
      }
    },
    "commands": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "limits": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "routes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": { "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" } }
}

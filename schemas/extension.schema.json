{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/0.2/extension.schema.json",
  "title": "ExtensionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "id", "version", "summary", "category", "tags", "maturity", "readme", "module", "capabilities", "commands", "providerCommands"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "id": { "$ref": "protocol.schema.json#/$defs/ExtensionId" },
    "version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "summary": { "$ref": "protocol.schema.json#/$defs/NonEmpty" },
    "category": { "enum": ["interaction", "cognition", "collaboration", "execution-safety", "ecosystem", "distribution", "planning-delivery", "forge"] },
    "tags": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "uniqueItems": true },
    "maturity": { "enum": ["experimental", "community", "verified", "official"] },
    "readme": { "type": "string", "pattern": "^\\./" },
    "module": { "type": "string", "pattern": "^\\./" },
    "capabilities": { "type": "array", "items": { "type": "string", "pattern": "^\\./" }, "uniqueItems": true },
    "dependencies": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/ExtensionId" }, "uniqueItems": true },
    "services": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "uniqueItems": true },
    "contributes": { "type": "array", "items": { "enum": ["attention", "agent-guidance", "authority-policy", "session-opening", "session-renderer", "provider-hooks", "onboarding", "input-resolver", "invocation-controls"] }, "uniqueItems": true },
    "relationTypes": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/DottedId" }, "uniqueItems": true },
    "intentModifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "argument", "values", "default"],
        "properties": {
          "id": { "$ref": "protocol.schema.json#/$defs/DottedId" },
          "argument": { "$ref": "protocol.schema.json#/$defs/Slug" },
          "values": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "minItems": 1, "uniqueItems": true },
          "default": { "$ref": "protocol.schema.json#/$defs/Slug" }
        }
      }
    },
    "agentGuidance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "targets"],
        "properties": {
          "id": { "$ref": "protocol.schema.json#/$defs/Id" },
          "source": { "type": "string", "pattern": "^\\./" },
          "targets": { "type": "array", "items": { "enum": ["AGENTS.md", "CLAUDE.md"] }, "minItems": 1, "uniqueItems": true },
          "roles": { "type": "array", "items": { "enum": ["forge", "distribution"] }, "minItems": 1, "uniqueItems": true }
        }
      }
    },
    "requiresCodebases": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "uniqueItems": true },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["namespace", "actions"],
        "properties": {
          "namespace": { "$ref": "protocol.schema.json#/$defs/Slug" },
          "actions": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "minItems": 1, "uniqueItems": true }
        }
      }
    },
    "providerCommands": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/ProviderCommand" } },
    "sourceDrivers": { "type": "array", "items": { "type": "string", "pattern": "^\\./" }, "uniqueItems": true },
    "methodologyBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "providers", "capabilities", "result"],
        "properties": {
          "id": { "$ref": "protocol.schema.json#/$defs/DottedId" },
          "providers": { "type": "array", "items": { "enum": ["codex", "claude"] }, "minItems": 1, "uniqueItems": true },
          "capabilities": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/Slug" }, "minItems": 1, "uniqueItems": true },
          "inputSchema": { "type": "string", "pattern": "^\\./" },
          "result": { "$ref": "protocol.schema.json#/$defs/ResultContract" },
          "instructions": { "type": "string", "pattern": "^\\./" }
        }
      }
    },
    "attention": { "type": "array", "items": { "$ref": "protocol.schema.json#/$defs/AttentionSignal" } },
    "preferences": { "type": "array", "items": { "type": "object" } },
    "onboarding": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "phase", "question", "options", "preferenceKey"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*$" },
          "phase": { "enum": ["privacy", "maintenance", "legacy", "domain"] },
          "question": { "$ref": "protocol.schema.json#/$defs/NonEmpty" },
          "options": { "type": "array", "items": { "type": "object" } },
          "preferenceKey": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*$" }
        }
      }
    },
    "artifactSchemas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "schema"],
        "properties": {
          "type": { "$ref": "protocol.schema.json#/$defs/Slug" },
          "schema": { "type": "string", "pattern": "^\\./" }
        }
      }
    }
  }
}

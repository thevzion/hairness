{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/v4/prologue.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "preferences", "facts", "signals"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/prologue/v1alpha1" },
    "kind": { "const": "Prologue" },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 120 },
        "addressAs": { "type": "string", "maxLength": 120 },
        "responseLanguage": { "type": "string", "maxLength": 32 },
        "note": { "type": "string", "maxLength": 500 }
      }
    },
    "facts": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "value"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" },
          "value": {
            "oneOf": [
              { "type": "string", "maxLength": 500 },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "signals": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "level", "message"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" },
          "level": { "enum": ["info", "warning", "error"] },
          "message": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    }
  }
}

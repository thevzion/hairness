{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schema/home.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "name", "runtime", "providers"],
  "properties": {
    "$schema": { "const": "https://hairness.dev/schema/home.json" },
    "name": { "$ref": "#/$defs/id" },
    "runtime": { "type": "string", "pattern": "^@hairness/cli@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "providers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["codex", "claude"] }
    },
    "targets": { "type": "array", "items": { "$ref": "#/$defs/target" } },
    "integrations": { "type": "array", "items": { "$ref": "#/$defs/integration" } },
    "config": { "type": "object" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repository"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "repository": { "type": "string", "minLength": 1, "maxLength": 512 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "accessors"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
        "accessors": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/accessor" } }
      }
    },
    "accessor": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "command"],
          "properties": { "kind": { "const": "cli" }, "command": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "provider", "id"],
          "properties": {
            "kind": { "const": "provider" },
            "provider": { "enum": ["codex", "claude"] },
            "id": { "type": "string", "minLength": 1, "maxLength": 160 }
          }
        }
      ]
    }
  }
}

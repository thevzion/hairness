{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schema/registry.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "name", "items"],
  "properties": {
    "$schema": { "const": "https://hairness.dev/schema/registry.json" },
    "name": { "$ref": "#/$defs/id" },
    "items": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "type", "title", "description", "files"],
      "properties": {
        "name": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
        "type": { "enum": ["hairness:extension", "hairness:home"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "registryDependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
        },
        "providers": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["codex", "claude"] }
        },
        "targets": { "type": "array", "items": { "type": "object" } },
        "integrations": { "type": "array", "items": { "type": "object" } },
        "config": { "type": "object" },
        "adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entry", "outputs"],
          "properties": {
            "id": { "$ref": "#/$defs/id" },
            "entry": { "$ref": "#/$defs/path" },
            "outputs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/path" } }
          }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "type"],
            "properties": {
              "path": { "$ref": "#/$defs/path" },
              "target": { "$ref": "#/$defs/path" },
              "type": { "enum": ["hairness:skill", "hairness:instruction", "hairness:file", "hairness:adapter"] },
              "id": { "$ref": "#/$defs/id" },
              "description": { "type": "string", "minLength": 1, "maxLength": 240 },
              "content": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schema/extension.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "name", "version", "description", "files"],
  "properties": {
    "$schema": { "const": "https://hairness.dev/schema/extension.json" },
    "name": { "$ref": "#/$defs/name" },
    "version": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "files": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "type"],
        "properties": {
          "path": { "$ref": "#/$defs/path" },
          "type": { "enum": ["hairness:instruction", "hairness:skill", "hairness:file"] },
          "id": { "$ref": "#/$defs/id" },
          "description": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entry", "outputs"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "entry": { "$ref": "#/$defs/path" },
        "outputs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/path" } }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "requestedRef", "resolvedCommit", "mobile", "baseManifestDigest", "baseDigests"],
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "requestedRef": { "type": ["string", "null"], "maxLength": 240 },
        "resolvedCommit": { "type": ["string", "null"], "maxLength": 64 },
        "mobile": { "type": "boolean" },
        "baseManifestDigest": { "$ref": "#/$defs/digest" },
        "baseDigests": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/path" },
          "additionalProperties": { "$ref": "#/$defs/digest" }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}/[a-z0-9][a-z0-9._-]{0,63}$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}

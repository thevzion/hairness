{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/v4/extension.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "hairness.dev/extension/v1alpha2" },
    "kind": { "const": "Extension" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "summary"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "instructions": {
          "type": "array",
          "items": { "$ref": "#/$defs/path" }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "summary", "path"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "summary": { "type": "string", "minLength": 1, "maxLength": 240 },
              "path": { "$ref": "#/$defs/path" }
            }
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "skill"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "skill": { "$ref": "#/$defs/id" },
              "summary": { "type": "string", "minLength": 1, "maxLength": 240 }
            }
          }
        },
        "prologue": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "$ref": "#/$defs/path" },
            "timeoutMs": { "type": "integer", "minimum": 50, "maximum": 2000 }
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "path"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "path": { "$ref": "#/$defs/path" }
            }
          }
        },
        "configSchema": { "$ref": "#/$defs/path" },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{0,127}$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    }
  }
}

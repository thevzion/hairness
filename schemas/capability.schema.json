{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hairness.dev/schemas/0.2/capability.schema.json",
  "title": "CapabilitySpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "protocolVersion", "id", "owner", "version", "summary", "operations"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "protocolVersion": { "const": "0.2" },
    "id": { "$ref": "protocol.schema.json#/$defs/ExtensionId" },
    "owner": { "$ref": "protocol.schema.json#/$defs/ExtensionId" },
    "version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "summary": { "$ref": "protocol.schema.json#/$defs/NonEmpty" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "protocol.schema.json#/$defs/Operation" }
    }
  }
}

{
  "apiVersion": "hairness.dev/home/v1alpha1",
  "kind": "Home",
  "metadata": {
    "id": "golden-home"
  },
  "spec": {
    "providers": ["codex", "claude"],
    "extensions": [
      "hairness/cockpit",
      "hairness/work",
      "hairness/sources",
      "hairness/delivery"
    ],
    "targets": [
      {
        "id": "product",
        "kind": "git",
        "summary": "Product",
        "requirement": "required",
        "remotes": ["git@example.test:acme/product.git"]
      }
    ],
    "config": {
      "hairness/sources": { "sources": [] }
    },
    "overlay": {
      "git": true,
      "snapshot": "boundary"
    }
  }
}
